{
  "type": "module",
  "scripts": {
    "build": "vite build .",
    "build:ssr": "vite build --ssr ssr.tsx --outDir dist",
    "build:ssr-auto": "vite build --config vite.config.ssr-auto.ts --ssr ssr-auto.tsx --outDir dist",
    "dev": "nodemon --watch . --watch ../../core/dist --watch ../../react/dist --ext js,tsx,html,json --ignore dist/ --exec 'vite build .'",
    "lint": "oxlint .",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "nodemon": "^3.1.14",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@inertiajs/core": "workspace:*",
    "@inertiajs/react": "workspace:*",
    "@inertiajs/vite": "workspace:*",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
