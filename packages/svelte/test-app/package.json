{
  "type": "module",
  "scripts": {
    "build": "vite build .",
    "build:ssr": "vite build --ssr ssr.ts --outDir dist",
    "build:ssr-auto": "vite build --config vite.config.ssr-auto.ts --ssr ssr-auto.ts --outDir dist",
    "dev": "nodemon --watch . --watch ../../core/dist --watch ../../svelte/dist --ext js,ts,svelte,html,json --ignore dist/ --exec 'vite build .'",
    "lint": "oxlint .",
    "type-check": "svelte-check --tsconfig ./tsconfig.json"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.10.13",
    "eslint-plugin-svelte": "^3.17.1",
    "nodemon": "^3.1.14",
    "svelte": "^5.55.7",
    "svelte-check": "^4.4.8",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@inertiajs/core": "workspace:*",
    "@inertiajs/svelte": "workspace:*",
    "@inertiajs/vite": "workspace:*"
  }
}
