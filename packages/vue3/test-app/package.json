{
  "type": "module",
  "scripts": {
    "build": "vite build .",
    "build:ssr": "vite build --ssr ssr.ts --outDir dist",
    "build:ssr-auto": "vite build --config vite.config.ssr-auto.ts --ssr ssr-auto.ts --outDir dist",
    "dev": "nodemon --watch . --watch ../../core/dist --watch ../../vue3/dist --ext js,vue,html,json --ignore dist/ --exec 'vite build .'",
    "lint": "oxlint .",
    "type-check": "vue-tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "@vitejs/plugin-vue": "^6.0.4",
    "nodemon": "^3.1.14",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vue": "^3.5.29",
    "vue-tsc": "^3.2.5"
  },
  "dependencies": {
    "@inertiajs/core": "workspace:*",
    "@inertiajs/vite": "workspace:*",
    "@inertiajs/vue3": "workspace:*"
  }
}
